{
  "$schema": "https://opencode.ai/config.json",

  "model": "ollama/qwen3.5:27b",
  "small_model": "ollama/qwen3:4b",

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://truenas.home.arpa:11434/v1"
      },
      "models": {
        "qwen3.5:27b": {
          "name": "Qwen 3.5 27B"
        },
        "qwen3.5:latest": {
          "name": "Qwen 3.5 27B"
        },
        "qwen3-coder:latest": {
          "name": "Qwen3-Coder-Next"
        },
        "qwen3:8b": {
          "name": "Qwen 3 8B"
        },
        "qwen3:4b": {
          "name": "Qwen 3 4B"
        }
      }
    }
  },

  "agent": {
    "architect": {
      "model": "ollama/qwen3.5:latest"
    },
    "builder": {
      "model": "ollama/qwen3-coder:latest"
    },
    "codebase": {
      "model": "ollama/qwen3.5:latest"
    },
    "git-operator": {
      "model": "ollama/qwen3:4b"
    },
    "docs-writer": {
      "model": "ollama/qwen3:8b"
    }
  }
}
