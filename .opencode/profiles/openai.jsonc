{
  "$schema": "https://opencode.ai/config.json",

  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5-mini",

  "provider": {
    "openai": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 45000,
        "setCacheKey": true
      },
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        },
        "gpt-5-mini": {
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        }
      }
    }
  },

  "agent": {
    "architect": {
      "model": "openai/gpt-5.4"
    },
    "builder": {
      "model": "openai/gpt-5.4"
    },
    "codebase": {
      "model": "openai/gpt-5.4"
    },
    "git-operator": {
      "model": "openai/gpt-5.4-mini"
    },
    "docs-writer": {
      "model": "openai/gpt-5.4-mini"
    }
  }
}
