{
  "$schema": "https://opencode.ai/config.json",

  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",

  "provider": {
    "openai": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 45000,
        "setCacheKey": true
      },
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        },
        "gpt-5.4-mini": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://truenas.home.arpa:11434/v1"
      },
      "models": {
        "qwen3-coder:latest": {
          "name": "Qwen3 Coder Latest"
        }
      }
    }
  },

  "agent": {
    "architect": {
      "model": "openai/gpt-5.4"
    },
    "builder": {
      "model": "ollama/qwen3-coder:latest"
    },
    "codebase": {
      "model": "openai/gpt-5.4"
    },
    "git-operator": {
      "model": "openai/gpt-5.4-mini"
    },
    "docs-writer": {
      "model": "openai/gpt-5.4-mini"
    }
  }
}
