border-size = 0
border-bottom = 0
border-top = 0
border-color = #00000000

padding-left = 2
padding-right = 2

module-margin-left = 1
module-margin-right = 2

font-0 = System San Francisco Display Regular:pixelsize=12;2
font-1 = Iosevka:style=Solid:size=15;2
font-2 = "Font Awesome 5 Free":style=Solid:size=14;0

modules-left = start i3
modules-center = date
modules-right = memory cpu pulseaudio light battery time powermenu

tray-position = right
tray-padding = 2
;tray-background = #0063ff

;wm-restack = bspwm
